{
  "schema_version": 2,
  "description": "Mandatory framework-to-tools binding. Agents must resolve tools_root and validate the required platform-truth files before doing any platform-truth-dependent work.",
  "paths": {
    "tools_root": "__CONFIGURE_TOOLS_ROOT__"
  },
  "validation": {
    "mode": "hard_fail",
    "required_paths": [
      "README.md",
      "docs/tools.md",
      "docs/session-model.md",
      "docs/agent-model.md",
      "spec/tool_catalog.json"
    ]
  },
  "mcp": {
    "server_name": "renderdoc-platform-mcp",
    "launch_command": [
      "python",
      "mcp/run_mcp.py"
    ]
  },
  "cli": {
    "launcher": "rdx.bat",
    "reference_doc": "debugger\\docs\\cli-mode-reference.md"
  }
}
