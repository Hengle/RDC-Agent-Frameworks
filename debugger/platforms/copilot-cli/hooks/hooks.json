{
    "PostToolUse":  [
                        {
                            "hooks":  [
                                          {
                                              "command":  "uv run --with pyyaml python common/hooks/utils/codebuddy_hook_dispatch.py write-bugcard",
                                              "description":  "Validate BugCard before write",
                                              "type":  "command"
                                          }
                                      ],
                            "matcher":  "Write"
                        },
                        {
                            "hooks":  [
                                          {
                                              "command":  "uv run --with pyyaml python common/hooks/utils/codebuddy_hook_dispatch.py write-skeptic",
                                              "description":  "Validate skeptic signoff artifact",
                                              "type":  "command"
                                          }
                                      ],
                            "matcher":  "Write"
                        }
                    ],
    "Stop":  [
                 {
                     "hooks":  [
                                   {
                                       "command":  "uv run --with pyyaml python common/hooks/utils/codebuddy_hook_dispatch.py stop-gate",
                                       "description":  "Finalization gate",
                                       "type":  "command"
                                   }
                               ]
                 }
             ]
}
